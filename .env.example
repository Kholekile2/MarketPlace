# Environment variables declared in this file are available at build time and runtime.
# Only variables prefixed by NEXT_PUBLIC_ are available in the browser.

# Database
DATABASE_URL="file:./dev.db"

# NextAuth.js
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# SMS Service (you would use a service like Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Email Service (you would use a service like SendGrid)
SENDGRID_API_KEY=""
FROM_EMAIL=""

# File Upload (you would use a service like Cloudinary)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
